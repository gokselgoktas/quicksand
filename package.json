{
    "name": "quicksand",
    "version": "0.1.0",
    "description": "A minimal app skeleton fueled by Electron, Express and React",
    "homepage": "https://github.com/gokselgoktas/quicksand",
    "bugs": {
        "url": "https://github.com/gokselgoktas/quicksand/issues"
    },
    "author": "Göksel Göktas",
    "main": "index.js",
    "repository": "github:gokselgoktas/quicksand",
    "scripts": {
        "clean": "rimraf ./build",
        "compile": "npm-run-all clean compile:development compile:production",
        "compile:development": "run-p compile:desktop+development compile:web+development",
        "compile:production": "run-p compile:desktop+production compile:web+production",
        "compile:desktop+development": "node ./build-scripts/build-system.js compile -t desktop -v development",
        "compile:desktop+production": "node ./build-scripts/build-system.js compile -t desktop -v production",
        "compile:web+development": "node ./build-scripts/build-system.js compile -t web -v development",
        "compile:web+production": "node ./build-scripts/build-system.js compile -t web -v production",
        "execute:desktop+development": "run-s compile:desktop+development && electron ./build/desktop/development",
        "execute:desktop+production": "run-s compile:desktop+production && electron ./build/desktop/production",
        "execute:web+development": "run-s compile:web+development && nodemon ./build/web/development/server/index.js",
        "execute:web+production": "run-s compile:web+production && node ./build/web/production/server/index.js",
        "package": "run-s package:desktop+production",
        "package:desktop+production": "node ./build-scripts/build-system.js package -t desktop -v production"
    },
    "dependencies": {
        "express": "^4.17.1",
        "react": "^17.0.1",
        "react-dom": "^17.0.1"
    },
    "engines": {
        "node": ">=15.0.1",
        "npm": "~7.5.4"
    },
    "private": true,
    "devDependencies": {
        "@babel/core": "^7.12.3",
        "@babel/preset-env": "^7.12.1",
        "@babel/preset-react": "^7.12.5",
        "@types/react": "^17.0.0",
        "@types/react-dom": "^17.0.0",
        "babel-loader": "^8.1.0",
        "clean-webpack-plugin": "^3.0.0",
        "commander": "^7.1.0",
        "css-loader": "^5.2.0",
        "css-minimizer-webpack-plugin": "^1.1.5",
        "electron": "^12.0.1",
        "electron-builder": "^22.10.5",
        "html-loader": "^2.1.1",
        "html-minimizer-webpack-plugin": "^2.1.0",
        "html-webpack-plugin": "^5.2.0",
        "mini-css-extract-plugin": "^1.2.1",
        "nodemon": "^2.0.6",
        "npm-run-all": "^4.1.5",
        "sass": "^1.29.0",
        "sass-loader": "^11.0.1",
        "webpack": "^5.4.0",
        "webpack-cli": "^4.2.0",
        "webpack-dev": "^1.1.1",
        "webpack-merge": "^5.7.3",
        "webpack-node-externals": "^2.5.2"
    }
}
